<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="009-add-lc-joined-at-column" author="codex">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="lc"/>
            <not>
                <columnExists tableName="lc" columnName="joined_at"/>
            </not>
        </preConditions>
        <addColumn tableName="lc">
            <column name="joined_at" type="datetime"/>
        </addColumn>
    </changeSet>

    <changeSet id="009-fill-lc-joined-at" author="codex">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="lc"/>
            <columnExists tableName="lc" columnName="joined_at"/>
        </preConditions>
        <sql>
            UPDATE lc SET joined_at = CURRENT_TIMESTAMP WHERE joined_at IS NULL;
        </sql>
    </changeSet>
</databaseChangeLog>
